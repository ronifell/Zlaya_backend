# Zlaya RN MVP — Backend environment variables
# Copy this file to .env and fill in the values you need.

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- LLM provider (OpenAI) ---
# If OPENAI_API_KEY is empty, the backend automatically falls back to a
# deterministic local engine (hash-based embeddings + rule-based composer)
# so the whole pilot remains runnable without external credentials.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval ---
# Minimum cosine similarity required to consider a chunk relevant.
RETRIEVAL_MIN_SIMILARITY=0.30
# Minimum aggregated confidence required to allow a direct answer.
ANSWER_MIN_CONFIDENCE=0.55
# Number of chunks retrieved before reranking.
RETRIEVAL_TOP_K=8
# Number of chunks kept after reranking.
RETRIEVAL_RERANK_K=4

# --- Audit / persistence ---
# If DATABASE_URL is set, audit logs are written to PostgreSQL.
# Otherwise they are appended to ./data/audit-log.jsonl
DATABASE_URL=

# --- Pilot scope guard ---
# The pilot is locked to the RN (0–28 days) namespace.
ACTIVE_NAMESPACES=RN
